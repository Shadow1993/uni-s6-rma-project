<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_detail_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Container Name"
            android:textSize="26sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_detail_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATUS: UNKNOWN"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Start"
                android:backgroundTint="#FF5722"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_stop"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Stop"
                android:backgroundTint="#FF5722"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deployment Details"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_detail_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Image: Unknown"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_detail_node"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Node: Unknown"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_detail_user"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Owner: Unknown"
            android:textSize="15sp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lifecycle Events"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_detail_created"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Created At: --"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tv_detail_started"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Started At: --"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tv_detail_stopped"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stopped At: --"
            android:textSize="14sp"/>
    </LinearLayout>
</ScrollView>